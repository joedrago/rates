{
    "name": "gacha-sim",
    "version": "1.0.0",
    "type": "module",
    "scripts": {
        "start": "node sim.mjs",
        "format": "prettier --write \"**/*.{js,mjs,cjs,json}\" --ignore-path .gitignore \"!.claude\"",
